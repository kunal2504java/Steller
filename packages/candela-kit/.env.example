# Copy to .env and fill in. .env is gitignored — never commit secrets.
# Consumed by playground/main.tsx via import.meta.env.

# Probatum v2 contract id (deployments/testnet.json).
VITE_CONTRACT_ID=

# Testnet secret of a friendbot-funded sponsor account that pays fees.
# Source: `stellar keys show spike-sponsor` (fund first, idempotent:
#   stellar keys fund spike-sponsor --network testnet).
VITE_FALLBACK_SECRET=
