# Copy to .env and fill in. .env is gitignored — never commit secrets.
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_CONTRACT_ID=CBDHK6NAGQBMWHAA442TJ4W7D2JJL5M5RB5NKA4PVZSWQAUVQ2A4CQSF

# Smart-wallet contract wasm hash, already installed on testnet.
# Source: kalepail/passkey-kit demo (next branch). Verified installed via RPC.
VITE_WALLET_WASM_HASH=ecd990f0b45ca6817149b6175f79b32efb442f35731985a084131e8265c4cd90

# Launchtube relay. testnet.launchtube.xyz does NOT resolve from this network,
# so the JWT is left empty and the local fallback (VITE_FALLBACK_SECRET) is used.
VITE_LAUNCHTUBE_URL=https://testnet.launchtube.xyz
VITE_LAUNCHTUBE_JWT=

# Testnet secret of a friendbot-funded account that pays fees (the sponsor).
# Create with: stellar keys generate spike-sponsor --network testnet
#              stellar keys fund spike-sponsor --network testnet
#              stellar keys show spike-sponsor   # -> paste secret here
VITE_FALLBACK_SECRET=
